# Server
PORT=8080
FRONTEND_URL=http://localhost:3000

# Firebase (Service Account)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# Apify
APIFY_API_TOKEN=your-apify-api-token

# Gmail OAuth2 — see README for how to get these
GMAIL_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
GMAIL_REFRESH_TOKEN=1//xxxxxxxxxxxx

# YouTube UGC (can reuse GMAIL_* credentials — enable YouTube Data API v3 in Google Cloud)
# Add redirect URI: https://your-backend.railway.app/api/ugc/youtube/oauth/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=
YOUTUBE_API_KEY=
BACKEND_URL=https://jarvis-production-42ed.up.railway.app

# Swiftdroom MRR sync — admin user's x-api-token from swiftdroom.com (Settings or DB)
SWIFTDROOM_API_URL=https://swiftdroom.com
SWIFTDROOM_ADMIN_API_TOKEN=
